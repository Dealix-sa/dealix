{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InvoiceStub",
  "description": "Operational stub. NOT a tax/legal invoice. Real invoices are issued through the customer's accounting system after manual review.",
  "type": "object",
  "required": ["id", "dealId", "amount", "currency", "createdAt", "demo"],
  "properties": {
    "id": { "type": "string" },
    "dealId": { "type": "string" },
    "accountId": { "type": "string" },
    "lineItems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "qty": { "type": "number" },
          "unitPrice": { "type": "number" },
          "subtotal": { "type": "number" }
        }
      }
    },
    "amount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "default": "SAR" },
    "createdAt": { "type": "string", "format": "date-time" },
    "vatNote": { "type": "string", "default": "VAT handled by customer's accounting system; this stub is not ZATCA-compliant." },
    "demo": { "type": "boolean" }
  }
}
