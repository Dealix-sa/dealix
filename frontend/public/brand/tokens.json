{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "version": "1.0.0",
  "effectiveDate": "2026-04-23",
  "source": "docs/sales-kit/dealix_brand_guidelines.md",
  "note": "Single source of truth for Dealix brand tokens. The interactive guide at /[locale]/brand reads this file directly.",
  "color": {
    "primary": {
      "deepGreen": { "value": "#0A4D3F", "rgb": [10, 77, 63], "hsl": [167, 77, 17], "usage": "Primary brand mark, headers, hero backgrounds" },
      "gold":      { "value": "#C9A961", "rgb": [201, 169, 97], "hsl": [37, 50, 58], "usage": "CTAs, accents, evidence cut line; max 10% of any surface" },
      "sand":      { "value": "#F4F0E8", "rgb": [244, 240, 232], "hsl": [40, 32, 93], "usage": "Light surfaces, light-mode backgrounds" }
    },
    "secondary": {
      "deepCharcoal": { "value": "#1A1A1A", "usage": "Body text on light surfaces" },
      "warmGray":     { "value": "#6B6B6B", "usage": "Secondary text, muted UI" },
      "coolGray":     { "value": "#E5E5E5", "usage": "Borders, dividers" }
    },
    "semantic": {
      "success": { "value": "#2D7A4F", "usage": "Success states, PASS verdicts" },
      "warning": { "value": "#E8A33D", "usage": "Warnings, partial-pass states" },
      "error":   { "value": "#C73E3E", "usage": "Errors, FAIL verdicts" },
      "info":    { "value": "#3B6B8C", "usage": "Informational notes" }
    }
  },
  "typography": {
    "arabic": {
      "primary":  { "family": "IBM Plex Sans Arabic", "weights": [300, 400, 500, 600, 700] },
      "fallback": { "family": "Tajawal", "weights": [300, 400, 500, 700] }
    },
    "english": {
      "primary":  { "family": "Inter", "weights": [400, 500, 600, 700] },
      "fallback": { "family": "system-ui", "weights": [400, 600, 700] },
      "code":     { "family": "JetBrains Mono", "weights": [400, 500] }
    },
    "scale": {
      "h1":      { "arabic": "48px", "english": "40px", "weight": 700, "lineHeight": 1.2 },
      "h2":      { "arabic": "36px", "english": "32px", "weight": 700, "lineHeight": 1.3 },
      "h3":      { "arabic": "28px", "english": "24px", "weight": 600, "lineHeight": 1.4 },
      "body":    { "arabic": "18px", "english": "16px", "weight": 400, "lineHeight": 1.6 },
      "caption": { "arabic": "14px", "english": "13px", "weight": 400, "lineHeight": 1.5 }
    }
  },
  "spacing": {
    "scale": "8px-grid",
    "values": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "2xl": 48, "3xl": 64 }
  },
  "radius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "card": "12px"
  },
  "rules": {
    "colorMix": "60% neutral + 30% Deep Green + 10% Gold",
    "forbidden": [
      "Green and Gold at equal weight — Gold is always accent",
      "Any color outside the primary/secondary/semantic palettes in marketing surfaces",
      "Marketing language with guaranteed outcomes (see doctrine no_overclaim)"
    ]
  },
  "assets": {
    "logoMark":     "/brand/logo-mark.svg",
    "logoWordmark": "/brand/logo-wordmark.svg",
    "favicon":      "/brand/favicon.svg"
  }
}
