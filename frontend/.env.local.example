# Dealix Frontend Environment Example
# Copy to frontend/.env.local for local development.
# Never commit real secrets.

NEXT_PUBLIC_APP_NAME=Dealix
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_ENABLE_OPS_AUTOPILOT=true
NEXT_PUBLIC_ENABLE_BUSINESS_NOW=true
NEXT_PUBLIC_ENABLE_FOUNDER_COCKPIT=true
NEXT_PUBLIC_ENABLE_APPROVALS=true
NEXT_PUBLIC_ENABLE_MARKETING_CALENDAR=true
