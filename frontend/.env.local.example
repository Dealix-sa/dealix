# ─────────────────────────────────────────────────────────────────────────
# Dealix Frontend — environment example  ·  مثال متغيرات بيئة الواجهة
# Copy to `.env.local` (gitignored) and fill values.  ·  انسخه إلى .env.local
#
# SECURITY: every NEXT_PUBLIC_* value is shipped to the browser. Never put a
# real admin key or secret behind a NEXT_PUBLIC_ prefix in production.
# الأمان: كل قيمة NEXT_PUBLIC_* تُرسَل للمتصفّح — لا تضع مفتاحاً سرياً خلفها.
# ─────────────────────────────────────────────────────────────────────────

# ── Public (browser-exposed) ──────────────────────────────────────────────

# Backend API base URL used by the public site + dashboard (src/lib/api.ts).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical public site URL (used for absolute links / metadata).
NEXT_PUBLIC_SITE_URL=https://dealix.me

# Route founder ops calls through the server-side proxy (1) instead of
# calling the API directly (0). Use 1 in production so admin keys stay server-side.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=0

# Display-only: Moyasar mode badge in the UI ("test" | "live").
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test

# Show operator/ops tooling in the UI (1) — keep 0 on the public marketing site.
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0

# Default actor name attached to approval actions in the ops UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# OPTIONAL — local development only. Lets the ops UI talk to the API without
# the proxy. Do NOT set this in production (it would expose the admin key).
# NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=
# NEXT_PUBLIC_DEMO_API_KEY=

# ── Server-only (NOT exposed to the browser — used by the proxy route) ─────

# Backend API base for the server-side proxy (defaults to NEXT_PUBLIC_API_URL).
DEALIX_API_URL=http://localhost:8000

# Admin API key used by the server-side ops proxy. Keep secret.
DEALIX_ADMIN_API_KEY=

# Shared secret allowing non-authenticated operator access via the proxy.
DEALIX_OPS_PROXY_SECRET=
