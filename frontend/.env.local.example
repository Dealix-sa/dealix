# Dealix frontend — local environment example
# Copy to .env.local and fill in real values:  cp .env.local.example .env.local
# Never commit .env.local (only this .example file is tracked).

# --- Public (browser-exposed) ---------------------------------------------
# FastAPI backend base URL. Local default below; in prod point to Railway.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public site URL (used for canonical/OG tags + absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Show operator/ops tooling in the UI (1 to enable locally; keep 0 in prod public).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0
# Moyasar display mode hint for the UI (test|live). Live charging is founder-flipped.
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test
# Actor label attached to approval-center actions taken from the UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# --- Ops console (admin) ---------------------------------------------------
# Prefer the server-side proxy in production so the admin key is NOT exposed
# to the browser. Set this to 1 and provide DEALIX_* server vars below.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=0
# Local-only convenience: admin key read directly by the browser ops pages.
# Leave blank in any shared/production deployment — use the proxy instead.
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=
# Demo API key for the public demo-request surface (optional, local only).
NEXT_PUBLIC_DEMO_API_KEY=

# --- Server-side only (NOT exposed to the browser) -------------------------
# Used by the Next.js route handlers under src/app/api/dealix-proxy/*.
# These never reach the client bundle — safe place for the admin key.
DEALIX_API_URL=http://localhost:8000
DEALIX_ADMIN_API_KEY=
DEALIX_OPS_PROXY_SECRET=
