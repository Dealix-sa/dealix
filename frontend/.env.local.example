# Dealix frontend (Next.js) — local development environment template.
#
# Copy to .env.local and fill values; .env.local is gitignored.
#
# Two operating modes:
#   1. Direct mode  → frontend calls api.dealix.me (or localhost:8000) and
#      attaches NEXT_PUBLIC_DEALIX_ADMIN_API_KEY itself. Used for local dev.
#   2. Proxy mode   → set NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1 so frontend
#      hits /api/dealix-proxy/* (a server-side Next route in
#      frontend/src/app/api/dealix-proxy/) which adds DEALIX_ADMIN_API_KEY
#      from the SERVER environment. Required for production so the admin
#      key never reaches the browser.

# ── 1. Backend base ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── 2. Public site URL (used by SEO + canonical links) ────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 3. Admin key for direct mode ──────────────────────────────────
# In production, leave the NEXT_PUBLIC_* one empty and set the unprefixed
# DEALIX_ADMIN_API_KEY on the server side (used by the proxy route).
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=
DEALIX_ADMIN_API_KEY=

# ── 4. Use the server-side proxy (production-safe) ────────────────
# 0 = direct mode (key visible to browser, dev only)
# 1 = proxy mode  (key stays on server)
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=0

# ── 5. Approval/demo (operator UI hints) ──────────────────────────
NEXT_PUBLIC_APPROVAL_ACTOR=founder
NEXT_PUBLIC_DEMO_API_KEY=
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0
