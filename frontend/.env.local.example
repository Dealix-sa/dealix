# Dealix Frontend — .env.local example
# Copy to .env.local for local dev. Do not commit .env.local.
# Production values live in the hosting provider (Railway / Vercel).

# ── Backend API base ─────────────────────────────────────────────
# Local dev backend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production backend (set in hosting provider)
# NEXT_PUBLIC_API_URL=https://api.dealix.me

# Public site URL (used in canonical links, OpenGraph, sitemaps)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://dealix.me

# ── Ops/Admin (founder cockpit only — never ship to public clients) ──
# When 1, browser calls go through Next.js API proxy that injects DEALIX_ADMIN_API_KEY server-side.
# Recommended for production so the admin key never leaks to the client.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1

# Server-only admin key used by the proxy route handlers in frontend/src/app/api/dealix-proxy/.
# Leave empty for local dev unless exercising /ops/* pages.
DEALIX_ADMIN_API_KEY=

# Backend base URL used by the proxy route handlers (server-side).
# Defaults to NEXT_PUBLIC_API_URL when unset.
DEALIX_API_URL=

# Shared secret between Next.js proxy and FastAPI (optional hardening).
DEALIX_OPS_PROXY_SECRET=

# Browser-side admin key — ONLY for local single-operator use; never set in prod.
# NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=

# ── Approval / actor identity (optional) ─────────────────────────
# Identifies the founder/operator when approving drafts from the UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# ── Demo / public surfaces ───────────────────────────────────────
# Show operational tooling chrome on demo pages (1 = show).
# NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=
# When API_KEYS is set on the backend, supply a valid key for browser demos.
# NEXT_PUBLIC_DEMO_API_KEY=

# ── Moyasar checkout mode (test|live) ────────────────────────────
# Sandbox by default. Switch to live only after MOYASAR_LIVE_CUTOVER.
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test
