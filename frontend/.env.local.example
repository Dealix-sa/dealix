# Dealix frontend — local development environment template.
# Copy this file to .env.local and adjust to your machine. Never commit .env.local.
#
# Every variable below is referenced in frontend/src/. The defaults shown are
# safe for local dev with the FastAPI backend on :8000.

# Backend API base URL (required).
# Used by: billing checkout, DSAR form, partner apply, proof pack samples,
# diagnostic landing, the cloud hub, and the dealix-proxy route handler.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used by sitemap + robots.txt + Open Graph absolute URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin API key — unlocks /ops/* dashboards locally.
# In production this MUST be set server-side; the proxy at /api/dealix-proxy
# strips it before forwarding to keep it out of the browser bundle.
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=dev

# Approvals center: who is recording the action. Set to your initials in dev.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# Demo API key for the public sprint tools (Risk Score sandbox).
NEXT_PUBLIC_DEMO_API_KEY=demo

# Feature flag — show internal operational tools on landing routes.
# Leave empty in production.
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=

# Production-only: route all admin-key calls through the server proxy so the
# key never reaches the browser. See frontend/src/app/api/dealix-proxy/.
# Set to 1 in production deploys.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=
