# Dealix legacy frontend (frontend/) — local environment example.
# Copy to .env.local for local Next.js development. Never commit real secrets.
# apps/web is the canonical frontend; this file keeps the legacy surface buildable.

# ── Public, browser-safe values ──────────────────────────────
# Canonical public site URL (metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://dealix.me
# Public API base URL for browser-safe calls.
NEXT_PUBLIC_API_URL=https://api.dealix.me
# Show internal operational tools in demo/admin surfaces (0 = off).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0
# Route privileged operations through a server-side proxy (1 = on, recommended).
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1
# Display-only label for who approves actions in the UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder
# Moyasar mode for demo flows (test | live). Keep "test" locally.
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test

# ── Server-side only (NOT exposed to the browser) ────────────
# Backend base URL used by server routes / the ops proxy.
DEALIX_API_URL=http://localhost:8000
# Admin API key — server-side ONLY. Never prefix with NEXT_PUBLIC_.
# Leave blank locally; inject via the deployment secret store.
DEALIX_ADMIN_API_KEY=
# Shared secret protecting the server-side ops proxy route.
DEALIX_OPS_PROXY_SECRET=
