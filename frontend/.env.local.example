# Dealix frontend (Next.js) — local environment example
# نسخة بيئة الواجهة الأمامية — انسخ هذا الملف إلى .env.local واملأ القيم
#
#   cp frontend/.env.local.example frontend/.env.local
#
# All NEXT_PUBLIC_* values are exposed to the browser — never put secrets there.
# قيم NEXT_PUBLIC_* مكشوفة للمتصفح — لا تضع فيها أسرارًا.

# ── Public (browser-exposed) ─────────────────────────────────────────────
# Backend API base URL. Default local backend is http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used for canonical links / SEO).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Route founder ops calls through the server-side Dealix proxy (recommended in prod).
# Set to 1 in production so the admin key stays server-side only.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=0

# Optional: admin key for operator-signal blocks rendered client-side (local/dev only).
# Leave empty in production — prefer the server proxy below.
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=

# Optional: demo API key for public demo surfaces.
NEXT_PUBLIC_DEMO_API_KEY=

# Moyasar display mode hint for the UI (test|live). Billing stays founder-flipped server-side.
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test

# Default actor label shown in the approval center UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# Show operational tooling in the UI (1 to enable; keep 0 for customer-facing builds).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0

# ── Server-only (NOT exposed to the browser) ─────────────────────────────
# Backend base URL used by the server-side Dealix proxy routes.
DEALIX_API_URL=http://localhost:8000

# Admin API key used server-side by the Dealix ops proxy. Keep this secret.
DEALIX_ADMIN_API_KEY=

# Shared secret guarding the ops proxy routes (server-side only).
DEALIX_OPS_PROXY_SECRET=
