# Dealix frontend (Next.js) environment — local development template.
# Copy to .env.local and fill values. NEVER commit a real .env.local.
# Privileged keys must stay server-side; only NEXT_PUBLIC_* reach the browser.

# ── Public (browser-exposed) ──────────────────────────────────────────
# Canonical site URL used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser-safe API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Show internal operational tools in admin surfaces (0 = hidden).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0

# Route privileged operations through the server-side proxy (1 = on).
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1

# Moyasar mode shown in the UI (test | live).
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test

# Actor label recorded on approval actions taken from the UI.
NEXT_PUBLIC_APPROVAL_ACTOR=founder

# Demo-only public API key (non-privileged, rate-limited demo surfaces).
NEXT_PUBLIC_DEMO_API_KEY=

# ── Server-side only (NOT exposed to the browser) ─────────────────────
# Backend API base URL used by Next.js server routes / proxy.
DEALIX_API_URL=http://localhost:8000

# Admin API key used by the server-side ops proxy. Keep secret.
DEALIX_ADMIN_API_KEY=

# Shared secret between the Next.js ops proxy and the backend.
DEALIX_OPS_PROXY_SECRET=
