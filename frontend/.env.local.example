# Dealix frontend (Next.js) — local environment template
# Copy to .env.local for local development. Do NOT commit real secrets.
# نموذج بيئة الواجهة الأمامية — انسخه إلى .env.local. لا تودِع أي أسرار حقيقية.

# --- Public site + API (browser-safe) ---
# Canonical public website URL (metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://dealix.me
# Public API base URL used by browser-safe calls.
NEXT_PUBLIC_API_URL=https://api.dealix.me

# --- Operational surfaces ---
# Show internal operational tools in demo/admin surfaces (0 = hidden, 1 = shown).
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0
# Keep privileged operations behind a server-side proxy (recommended: 1).
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1

# --- Payments (Moyasar) ---
# Moyasar mode is TEST by default. Live mode is founder-flipped only.
# وضع Moyasar افتراضيًا تجريبي. الوضع المباشر يُفعّله المؤسس فقط.
NEXT_PUBLIC_DEALIX_MOYASAR_MODE=test

# --- Approval + admin (local/dev only) ---
# Actor name attached to approval-center requests in local dev.
NEXT_PUBLIC_APPROVAL_ACTOR=founder
# Admin API key for local dev only. Never ship a real key to the browser bundle;
# prefer the server-side ops proxy (NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1) in production.
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=
# Demo API key for public demo surfaces (local/dev only).
NEXT_PUBLIC_DEMO_API_KEY=
