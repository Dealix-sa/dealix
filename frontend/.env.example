# Dealix frontend (Next.js) — public env contract.
# Copy to .env.local for local dev. Only NEXT_PUBLIC_* values reach the browser.

# Base URL of the Dealix FastAPI backend.
NEXT_PUBLIC_API_URL=https://api.dealix.me

# Optional: admin API key for the founder/ops dashboards. Leave EMPTY in any
# public deployment — without it, ops calls route through the server-side proxy
# (see NEXT_PUBLIC_USE_DEALIX_OPS_PROXY) instead of exposing the key in-browser.
NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=

# Set to "1" to route ops-autopilot/evidence/support calls through the
# server-side /api/dealix-proxy route instead of sending an admin key from the
# browser. Recommended for any internet-facing deployment.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1
