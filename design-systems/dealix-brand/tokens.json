{
  "$schema": "https://schemas.dealix.com/design-tokens-1.0.json",
  "name": "dealix-brand",
  "version": "1.0.0",
  "description": "Brand-layer design tokens for Dealix (Deep Navy + Emerald Teal). Separate from the operational design system at design-systems/dealix. Companion to docs/brand/BRAND_GUIDELINES.md.",
  "color": {
    "brand": {
      "navy":   { "value": "#0B1220", "type": "color", "notes": "Primary dark surface." },
      "teal":   { "value": "#00D1A1", "type": "color", "notes": "Accent — on-dark only. Fails WCAG AA on white." },
      "silver": { "value": "#B2BBC6", "type": "color", "notes": "On-dark muted. Fails WCAG AA on white." },
      "slate":  { "value": "#0F1726", "type": "color", "notes": "Alt dark surface." },
      "white":  { "value": "#FFFFFF", "type": "color" },
      "teal-ink": { "value": "#007A5C", "type": "color", "notes": "Teal for light backgrounds — passes AA (5.3:1 on white)." }
    },
    "text": {
      "muted-light": { "value": "#6B7480", "type": "color", "notes": "Body muted on white — AA pass (4.6:1)." }
    },
    "surface": {
      "tint-navy": { "value": "#E8EBF1", "type": "color", "notes": "1.5% navy tint for light-mode alt surfaces." }
    },
    "state": {
      "success": { "value": "#10B981", "type": "color" },
      "warn":    { "value": "#F59E0B", "type": "color" },
      "danger":  { "value": "#EF4444", "type": "color" },
      "info":    { "value": "#60A5FA", "type": "color" }
    },
    "gradient": {
      "teal": {
        "value": "linear-gradient(135deg, #00D1A1 0%, #00A37C 100%)",
        "type": "gradient",
        "notes": "The only sanctioned brand gradient. Used on the logo arrow and primary CTA on dark."
      }
    },
    "semantic": {
      "dark": {
        "bg":           { "value": "{color.brand.navy}" },
        "bg-alt":       { "value": "{color.brand.slate}" },
        "text":         { "value": "{color.brand.white}" },
        "text-muted":   { "value": "{color.brand.silver}" },
        "accent":       { "value": "{color.brand.teal}" },
        "on-accent":    { "value": "{color.brand.navy}" }
      },
      "light": {
        "bg":           { "value": "{color.brand.white}" },
        "bg-alt":       { "value": "{color.surface.tint-navy}" },
        "text":         { "value": "{color.brand.navy}" },
        "text-muted":   { "value": "{color.text.muted-light}" },
        "accent":       { "value": "{color.brand.teal-ink}" },
        "on-accent":    { "value": "{color.brand.white}" }
      }
    }
  },
  "font": {
    "display": {
      "value": "\"Space Grotesk\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
      "type": "fontFamily"
    },
    "ui": {
      "value": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
      "type": "fontFamily"
    },
    "ar": {
      "value": "\"IBM Plex Sans Arabic\", system-ui, \"Geeza Pro\", \"Tahoma\", sans-serif",
      "type": "fontFamily"
    },
    "mono": {
      "value": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", \"Cascadia Code\", monospace",
      "type": "fontFamily"
    }
  },
  "type": {
    "display": {
      "xl": { "size": "4rem",     "line-height": 1.05, "weight": 700, "family": "{font.display}" },
      "l":  { "size": "3rem",     "line-height": 1.10, "weight": 700, "family": "{font.display}" },
      "m":  { "size": "2.25rem",  "line-height": 1.15, "weight": 600, "family": "{font.display}" }
    },
    "heading": {
      "l": { "size": "1.75rem",  "line-height": 1.25, "weight": 600, "family": "{font.display}" },
      "m": { "size": "1.375rem", "line-height": 1.30, "weight": 600, "family": "{font.ui}" },
      "s": { "size": "1.125rem", "line-height": 1.35, "weight": 600, "family": "{font.ui}" }
    },
    "body": {
      "l": { "size": "1.125rem", "line-height": 1.55, "weight": 400, "family": "{font.ui}" },
      "m": { "size": "1rem",     "line-height": 1.55, "weight": 400, "family": "{font.ui}" },
      "s": { "size": "0.875rem", "line-height": 1.50, "weight": 400, "family": "{font.ui}" }
    },
    "mono": {
      "m": { "size": "0.875rem", "line-height": 1.50, "weight": 500, "family": "{font.mono}" }
    },
    "arabic-line-height-multiplier": 1.10
  },
  "space": {
    "0": { "value": "0",     "type": "spacing" },
    "1": { "value": "4px",   "type": "spacing" },
    "2": { "value": "8px",   "type": "spacing" },
    "3": { "value": "12px",  "type": "spacing" },
    "4": { "value": "16px",  "type": "spacing" },
    "5": { "value": "24px",  "type": "spacing" },
    "6": { "value": "32px",  "type": "spacing" },
    "7": { "value": "48px",  "type": "spacing" },
    "8": { "value": "64px",  "type": "spacing" },
    "9": { "value": "96px",  "type": "spacing" }
  },
  "radius": {
    "sm":   { "value": "6px"    },
    "md":   { "value": "10px"   },
    "lg":   { "value": "14px"   },
    "xl":   { "value": "20px"   },
    "full": { "value": "9999px" }
  },
  "shadow": {
    "sm":         { "value": "0 1px 2px rgba(0,0,0,0.20)" },
    "md":         { "value": "0 4px 12px rgba(0,0,0,0.25)" },
    "lg":         { "value": "0 16px 40px rgba(0,0,0,0.35)" },
    "glow-teal":  { "value": "0 0 24px rgba(0,209,161,0.25)", "notes": "Use sparingly — CTA hover and hero accent only." }
  },
  "motion": {
    "duration": {
      "fast": { "value": "120ms" },
      "base": { "value": "200ms" },
      "slow": { "value": "320ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0, 0, 1)" },
      "entrance": { "value": "cubic-bezier(0.0, 0, 0.2, 1)" },
      "exit":     { "value": "cubic-bezier(0.4, 0, 1, 1)" }
    }
  },
  "breakpoint": {
    "sm":  { "value": "560px" },
    "md":  { "value": "720px" },
    "lg":  { "value": "1024px" },
    "xl":  { "value": "1280px" },
    "2xl": { "value": "1536px" }
  },
  "z": {
    "base":     { "value": 0  },
    "raised":   { "value": 10 },
    "dropdown": { "value": 20 },
    "overlay":  { "value": 30 },
    "modal":    { "value": 40 },
    "toast":    { "value": 50 },
    "tooltip":  { "value": 60 }
  }
}
