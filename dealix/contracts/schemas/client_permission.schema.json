{
  "additionalProperties": false,
  "description": "A single permission the client is asked to grant.",
  "properties": {
    "permission_id": {
      "title": "Permission Id",
      "type": "string"
    },
    "level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ],
      "title": "Level",
      "type": "string"
    },
    "system": {
      "default": "",
      "title": "System",
      "type": "string"
    },
    "scope": {
      "default": "",
      "title": "Scope",
      "type": "string"
    },
    "purpose_ar": {
      "default": "",
      "title": "Purpose Ar",
      "type": "string"
    },
    "risk": {
      "default": "low",
