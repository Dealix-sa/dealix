# Dealix API Server — Environment Variables
# Copy to .env and fill in real values.

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=8000

# ── Database (PostgreSQL) ─────────────────────────────────────
# Local: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres -d postgres:16
# Production: use Supabase / Neon / Railway / Render Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealix
PG_POOL_MAX=10

# ── JWT Auth ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ── Admin / Internal Gates ────────────────────────────────────
DEALIX_ADMIN_API_KEY=replace-with-strong-admin-key
DEALIX_INTERNAL_TOKEN=replace-with-strong-internal-token

# ── AI Integration ────────────────────────────────────────────
# Either OpenAI or Anthropic — both are optional; static fallback if missing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_INTERNAL=500

# ── WebSocket / Workers ───────────────────────────────────────
WS_HEARTBEAT_MS=7000
WORKER_STALE_MINUTES=30

# ── Logging ───────────────────────────────────────────────────
ENABLE_REQUEST_LOG=1
