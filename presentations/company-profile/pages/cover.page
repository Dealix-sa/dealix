pageType: cover
background:
  type: solid
  color: "$dark"
elements:
  - elementId: bg-image
    elementType: image
    bounds: [0, 0, 1280, 720]
    src: "/mnt/agents/output/dealix-marketing/brand/hero-bg-dark.jpg"
    opacity: 0.4
  - elementId: overlay
    elementType: shape
    bounds: [0, 0, 1280, 720]
    shapeName: rectangle
    fill:
      type: gradient
      colors: ["#1A1A1AEE", "#1A1A1ACC"]
      angle: 180
  - elementId: logo
    elementType: image
    bounds: [540, 160, 200, 200]
    src: "/mnt/agents/output/dealix-marketing/brand/dealix-logo-primary.png"
  - elementId: gold-line
    elementType: shape
    bounds: [540, 380, 200, 3]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: title
    elementType: text
    bounds: [240, 400, 800, 70]
    content:
      style: "$coverTitle"
      text: |
        <p>Dealix</p>
      align: center
  - elementId: subtitle-ar
    elementType: text
    bounds: [240, 480, 800, 40]
    content:
      fontSize: 24
      color: "$accent"
      fontFamily: "alimamashuheiti"
      text: |
        <p>نظام تشغيل الإيرادات بالذكاء الاصطناعي</p>
      align: center
  - elementId: subtitle-en
    elementType: text
    bounds: [240, 520, 800, 30]
    content:
      fontSize: 16
      color: "#FFFFFF99"
      fontFamily: "QuattrocentoSans"
      letterSpacing: 4
      text: |
        <p>AI REVENUE OPERATING SYSTEM</p>
      align: center
  - elementId: year-badge
    elementType: text
    bounds: [540, 580, 200, 24]
    content:
      fontSize: 14
      color: "#FFFFFF66"
      fontFamily: "Liter"
      letterSpacing: 6
      text: |
        <p>SAUDI ARABIA  2025</p>
      align: center
