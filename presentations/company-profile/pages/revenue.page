pageType: content
background:
  type: solid
  color: "$dark"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>REVENUE MODEL  //  نموذج الإيرادات</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      fontSize: 36
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      text: |
        <p>نموذج إيرادات واضح ومربح</p>
      wrap: false
  - elementId: funnel-label
    elementType: text
    bounds: [60, 170, 300, 24]
    content:
      fontSize: 14
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 2
      wrap: false
      text: |
        <p>CONVERSION FUNNEL</p>
