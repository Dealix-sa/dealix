pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>COMPETITIVE EDGE  //  المزايا التنافسية</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      style: "$title"
      text: |
        <p>لماذا Dealix؟</p>
      wrap: false
  - elementId: card1-bg
    elementType: shape
    bounds: [60, 170, 370, 240]
    shapeName: rectangle
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E5E5E5"
  - elementId: card1-accent
    elementType: shape
    bounds: [60, 170, 5, 240]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: card1-icon
    elementType: icon
    bounds: [90, 195, 36, 36]
    iconName: shield-check
    color: "$primary"
  - elementId: card1-title
    elementType: text
    bounds: [90, 245, 320, 30]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p>متوافق مع PDPL وZATCA</p>
  - elementId: card1-desc
    elementType: text
    bounds: [90, 285, 320, 100]
    content:
      fontSize: 16
      color: "$muted"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.5
      text: |
        <p>أول منصة سعودية تلبي متطلبات حماية البيانات والفوترة الإلكترونية</p>
