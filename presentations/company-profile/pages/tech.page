pageType: content
background:
  type: solid
  color: "$dark"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>TECHNICAL ARCHITECTURE  //  البنية التقنية</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 800, 50]
    content:
      fontSize: 36
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      text: |
        <p>بنية تقنية متكاملة وقابلة للتوسع</p>
      wrap: false
  - elementId: arch-label
    elementType: text
    bounds: [60, 170, 400, 24]
