pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>MILESTONES  //  الإنجازات</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      style: "$title"
      text: |
        <p>ما أنجزناه حتى الآن</p>
      wrap: false
  - elementId: m1-bg
    elementType: shape
    bounds: [60, 170, 270, 240]
    shapeName: rectangle
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E5E5E5"
  - elementId: m1-num
    elementType: text
    bounds: [80, 190, 230, 60]
    content:
      fontSize: 48
      color: "$accent"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p>575</p>
  - elementId: m1-label
    elementType: text
    bounds: [80, 255, 230, 30]
    content:
      fontSize: 18
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p>Commit في الريبو</p>
  - elementId: m1-desc
    elementType: text
    bounds: [80, 295, 230, 80]
    content:
      fontSize: 14
      color: "$muted"
      fontFamily: "QuattrocentoSans, MiSans"
