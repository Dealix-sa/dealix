pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>TARGET SECTORS  //  القطاعات المستهدفة</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      style: "$title"
      text: |
        <p>حلول لكل قطاع في السوق السعودي</p>
      wrap: false
  - elementId: s1-bg
    elementType: shape
    bounds: [60, 170, 370, 240]
    shapeName: rectangle
    fill:
      type: solid
      color: "$light"
    border:
      style: solid
      width: 1
      color: "#E5E5E5"
  - elementId: s1-icon
    elementType: icon
    bounds: [85, 195, 32, 32]
    iconName: building-2
    color: "$primary"
  - elementId: s1-title
    elementType: text
    bounds: [85, 240, 320, 30]
    content:
      fontSize: 20
      color: "$text"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p>العقارات والمقاولات</p>
  - elementId: s1-desc
    elementType: text
    bounds: [85, 280, 320, 100]
    content:
      fontSize: 16
      color: "$muted"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.5
      text: |
        <p>إدارة المشاريع، مبيعات الوحدات، تحليل السوق العقاري</p>
  - elementId: s2-bg
    elementType: shape
    bounds: [455, 170, 370, 240]
