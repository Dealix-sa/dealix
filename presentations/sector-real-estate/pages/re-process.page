pageType: content
background:
  type: solid
  color: "$dark"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 400, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>PROCESS  //  عملية التنفيذ</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      fontSize: 36
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      text: |
        <p>كيف نبدأ معاً؟</p>
      wrap: false
  - elementId: step1-bg
    elementType: shape
    bounds: [60, 180, 260, 380]
    shapeName: rectangle
    fill:
      type: solid
      color: "#FFFFFF08"
    border:
      style: solid
      width: 1
      color: "#FFFFFF15"
  - elementId: step1-num
    elementType: text
    bounds: [80, 200, 100, 50]
    content:
      fontSize: 36
      color: "$accent"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p>01</p>
  - elementId: step1-title
    elementType: text
    bounds: [80, 260, 220, 30]
    content:
      fontSize: 20
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p>التشخيص المجاني</p>
  - elementId: step1-desc
    elementType: text
    bounds: [80, 300, 220, 120]
    content:
      fontSize: 14
      color: "#FFFFFF99"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.5
      text: |
        <p>نحلل أعمالك الحالية ونحدد فرص النمو والتحسين خلال 30 دقيقة</p>
  - elementId: arrow1
