pageType: content
background:
  type: solid
  color: "$dark"
elements:
  - elementId: header-bar
    elementType: shape
    bounds: [60, 50, 4, 30]
    shapeName: rectangle
    fill:
      type: solid
      color: "$accent"
  - elementId: header-label
    elementType: text
    bounds: [76, 48, 300, 30]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 3
      wrap: false
      text: |
        <p>THE SOLUTION  //  الحل</p>
  - elementId: title
    elementType: text
    bounds: [60, 90, 700, 50]
    content:
      fontSize: 36
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      text: |
        <p>Dealix — منصة العقارات الذكية</p>
      wrap: false
  - elementId: solution-desc
    elementType: text
    bounds: [60, 160, 600, 80]
    content:
      fontSize: 18
      color: "#FFFFFFCC"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.6
      text: |
        <p>منصة متكاملة تغطي كل احتياجات الشركة العقارية: من إدارة العملاء إلى تحليل السmarket وإدارة المشاريع</p>
  - elementId: f1-bg
    elementType: shape
    bounds: [60, 260, 370, 190]
    shapeName: rectangle
    fill:
      type: solid
      color: "#FFFFFF08"
    border:
      style: solid
      width: 1
      color: "#FFFFFF15"
  - elementId: f1-icon
    elementType: icon
    bounds: [85, 285, 32, 32]
    iconName: users
    color: "$accent"
  - elementId: f1-title
    elementType: text
    bounds: [85, 330, 320, 30]
    content:
      fontSize: 20
      color: "$white"
      fontFamily: "Liter, alimamashuheiti"
      wrap: false
      text: |
        <p>CRM عقاري متكامل</p>
  - elementId: f1-desc
    elementType: text
