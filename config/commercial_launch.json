{
  "schema_version": "3.0",
  "name": "Dealix Official Commercial Launch OS",
  "identity": {
    "en": "Dealix is a Saudi/GCC B2B AI Revenue & Operations OS.",
    "ar": "ديالكس نظام تشغيل ذكاء اصطناعي للإيرادات والعمليات بين الشركات في السعودية والخليج."
  },
  "doctrine": {
    "ai_role": "AI generates and ranks drafts only.",
    "human_role": "Founder reviews and approves every external action.",
    "human_in_the_loop": true,
    "no_external_sending": true,
    "no_whatsapp_cold_outreach": true,
    "no_linkedin_automation": true,
    "no_smtp": true,
    "no_scraping": true,
    "no_secrets": true,
    "no_api_keys": true,
    "no_auto_submit_forms": true
  },
  "draft_factory": {
    "daily_target": 400,
    "output_root": "outputs/commercial_launch"
  },
  "mandatory_draft_flags": {
    "send_allowed": false,
    "external_send_blocked": true,
    "requires_founder_approval": true,
    "no_auto_send": true
  },
  "allowed_statuses": [
    "founder_review",
    "needs_research",
    "rejected_quality",
    "rejected_compliance",
    "ready_for_manual_copy",
    "archived"
  ],
  "forbidden_statuses": [
    "sent",
    "auto_sent",
    "queued_for_send",
    "smtp_ready",
    "whatsapp_ready",
    "linkedin_auto_ready"
  ],
  "currency": "SAR",
  "geography": ["SA", "AE", "KW", "QA", "BH", "OM"]
}
