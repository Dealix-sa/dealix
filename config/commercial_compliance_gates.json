  "privacy_first_verticals": ["legal_professional_services"],
  "privacy_first_required_markers_en": ["privacy", "consent", "your control", "data minimization", "you approve"],
  "privacy_first_required_markers_ar": ["الخصوصية", "موافقتك", "تحت سيطرتك", "تقليل البيانات", "أنت تعتمد"],
  "whatsapp_requires_opt_in": true,
  "linkedin_automation_banned": true,
  "website_auto_submit_banned": true
