{
  "name": "dealix-monorepo",
  "private": true,
  "version": "5.0.0",
  "description": "Dealix Backend v5 — Full Production Engine",
  "scripts": {
    "build": "pnpm --filter @workspace/db build && pnpm --filter @workspace/api-server build",
    "typecheck": "pnpm --filter @workspace/db typecheck && pnpm --filter @workspace/api-server typecheck",
    "dev": "pnpm --filter @workspace/api-server dev",
    "start": "pnpm --filter @workspace/api-server start",
    "seed": "pnpm --filter @workspace/api-server run seed",
    "db:push": "pnpm --filter @workspace/db push"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
