# ═══════════════════════════════════════════════════════════════
# Dealix — Production Environment Variables Template
# Copy values into Railway dashboard → Service → Variables
# DO NOT commit this file with real values
# ═══════════════════════════════════════════════════════════════

# ── Core App ─────────────────────────────────────────────────
APP_ENV=production
ENVIRONMENT=production
APP_URL=https://api.dealix.me
BASE_URL=https://api.dealix.me
DEALIX_API_BASE=https://api.dealix.me
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ── Database (Railway injects via reference variable) ────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── CORS (comma-separated origins) ──────────────────────────
CORS_ORIGINS=https://dealix.me,https://www.dealix.me,https://api.dealix.me

# ── Controlled Live Outbound ─────────────────────────────────
EXTERNAL_SEND_ENABLED=true
OUTBOUND_MODE=controlled_live
OUTBOUND_REQUIRE_APPROVAL=true
OUTBOUND_REQUIRE_VERIFIED_TARGET=true
OUTBOUND_REQUIRE_SOURCE_URL=true
OUTBOUND_REQUIRE_OPT_OUT=true
OUTBOUND_BLOCK_FAKE_CLAIMS=true
OUTBOUND_BLOCK_GUARANTEED_ROI=true

COMMAND_ROOM_ENABLED=true
CEO_DAILY_REPORT_ENABLED=true
REPLY_CLASSIFICATION_ENABLED=true
OUTREACH_TIMEZONE=Asia/Riyadh

# ── Email ─────────────────────────────────────────────────────
EMAIL_SEND_ENABLED=true
EMAIL_SEND_MODE=live
EMAIL_PROVIDER=smtp
EMAIL_DAILY_LIMIT=25
EMAIL_BATCH_LIMIT=10
EMAIL_MIN_SECONDS_BETWEEN_SENDS=90
EMAIL_REQUIRE_UNSUBSCRIBE=true
EMAIL_TRACK_REPLIES=true
EMAIL_REPLY_TO=sami@dealix.me
EMAIL_DEFAULT_FROM=sami@dealix.me

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_SEND_ENABLED=true
WHATSAPP_ALLOW_LIVE_SEND=true
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_SEND_MODE=template_only
WHATSAPP_DAILY_LIMIT=10
WHATSAPP_BATCH_LIMIT=5
WHATSAPP_MIN_SECONDS_BETWEEN_SENDS=120
WHATSAPP_REQUIRE_OPT_IN=true
WHATSAPP_REQUIRE_APPROVED_TEMPLATE=true
WHATSAPP_STOP_KEYWORDS=STOP,UNSUBSCRIBE,إيقاف,الغاء,إلغاء

# ── Secrets (generate separately; NEVER commit real values) ───
# APP_SECRET_KEY=<generate-64-char-hex>
# JWT_SECRET_KEY=<generate-64-char-hex>
# API_KEYS=<your-api-key-1>,<your-api-key-2>
# ADMIN_API_KEYS=<your-admin-key>
# DEALIX_ADMIN_API_KEY=<your-dealix-admin-key>
# SMTP_HOST=<your-smtp-host>
# SMTP_USER=<your-smtp-user>
# SMTP_PASSWORD=<your-smtp-password>
# META_PHONE_NUMBER_ID=<your-meta-phone-number-id>
# META_WA_ACCESS_TOKEN=<your-meta-wa-access-token>
