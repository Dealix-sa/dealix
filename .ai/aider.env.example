# Source this file before running aider, or copy values into your shell profile.
# Windows PowerShell equivalent:
#   set OPENAI_API_BASE=http://localhost:4000/v1
#   set OPENAI_API_KEY to your local LiteLLM master key
#   aider --model openai/dealix-code

export OPENAI_API_BASE="http://localhost:4000/v1"
# Do not commit real keys. Set OPENAI_API_KEY in your local shell.

# Recommended:
#   aider --model openai/dealix-code
# Hard tasks:
#   aider --model openai/dealix-smart
