# ═══════════════════════════════════════════════════════════════
# Dealix — Railway Environment Variables Template
# Copy to Railway dashboard → Service → Variables
# DO NOT commit this file with real values
# ═══════════════════════════════════════════════════════════════

# ── Core App ─────────────────────────────────────────────────
APP_ENV=production
ENVIRONMENT=production
APP_URL=https://api.dealix.me
BASE_URL=https://api.dealix.me
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# ── Dockerfile path (Railway auto-detects) ───────────────────
RAILWAY_DOCKERFILE_PATH=Dockerfile

# ── Database (Railway injects via reference variable) ────────
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
APP_SECRET_KEY=<generate-64-char-hex>
JWT_SECRET_KEY=<generate-64-char-hex>

# ── API Keys (comma-separated) ──────────────────────────────
API_KEYS=<your-api-key-1>,<your-api-key-2>
ADMIN_API_KEYS=<your-admin-key>
DEALIX_ADMIN_API_KEY=<your-dealix-admin-key>

# ── CORS (comma-separated origins) ──────────────────────────
CORS_ORIGINS=https://dealix.me,https://app.dealix.me,https://api.dealix.me

# ── LLM Providers (optional — set the ones you use) ─────────
# ANTHROPIC_API_KEY=
# Hermes Agents (falls back to ANTHROPIC_API_KEY if HERMES_API_KEY not set)
# HERMES_API_KEY=
# HERMES_MODEL=claude-opus-4-8
# HERMES_COST_BUDGET_USD=5.0
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-Text-01
# MINIMAX_OUTREACH_MAX_PER_DAY=20
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=

# ── Email (optional) ────────────────────────────────────────
# RESEND_API_KEY=
# DEALIX_FOUNDER_EMAIL=sami.assiri11@gmail.com

# ── WhatsApp (optional — production only after legal) ───────
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ALLOW_LIVE_SEND=false

# ── HubSpot (optional) ─────────────────────────────────────
# HUBSPOT_ACCESS_TOKEN=
# HUBSPOT_PORTAL_ID=

# ── Observability (optional) ────────────────────────────────
# SENTRY_DSN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ── ZATCA E-Invoice (optional) ──────────────────────────────
# ZATCA_CSID=
# ZATCA_SECRET=
# ZATCA_SANDBOX=true

# ── Worker-specific (founder-os-worker service only) ────────
# FOUNDER_OS_INTERVAL_SECONDS=900
# AGENT_APPROVAL_MODE=required
# AUTO_SEND_ENABLED=false
# EXTERNAL_OUTREACH_ENABLED=false

# ── Watchdog-specific (dealix-watchdog cron only) ───────────
# DEALIX_API_URL=https://api.dealix.me
# DEALIX_HEALTH_PATH=/healthz

# ── Controlled Live Outbound (Dealix Company OS) ────────────
# Reference: docs/ops/CONTROLLED_LIVE_OUTBOUND.md
EXTERNAL_SEND_ENABLED=true
OUTBOUND_MODE=controlled_live
OUTBOUND_REQUIRE_APPROVAL=true
OUTBOUND_REQUIRE_VERIFIED_TARGET=true
OUTBOUND_REQUIRE_SOURCE_URL=true
OUTBOUND_REQUIRE_OPT_OUT=true
OUTBOUND_BLOCK_FAKE_CLAIMS=true
OUTBOUND_BLOCK_GUARANTEED_ROI=true

COMMAND_ROOM_ENABLED=true
CEO_DAILY_REPORT_ENABLED=true
REPLY_CLASSIFICATION_ENABLED=true
OUTREACH_TIMEZONE=Asia/Riyadh

EMAIL_SEND_ENABLED=true
EMAIL_SEND_MODE=live
EMAIL_PROVIDER=smtp
EMAIL_DAILY_LIMIT=25
EMAIL_BATCH_LIMIT=10
EMAIL_MIN_SECONDS_BETWEEN_SENDS=90
EMAIL_REQUIRE_UNSUBSCRIBE=true
EMAIL_TRACK_REPLIES=true
EMAIL_REPLY_TO=sami@dealix.me
EMAIL_DEFAULT_FROM=sami@dealix.me
SMTP_HOST=<your-smtp-host>
SMTP_PORT=587
SMTP_USER=<your-smtp-user>
SMTP_PASSWORD=<your-smtp-password>

WHATSAPP_SEND_ENABLED=true
WHATSAPP_ALLOW_LIVE_SEND=true
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_SEND_MODE=template_only
WHATSAPP_DAILY_LIMIT=10
WHATSAPP_BATCH_LIMIT=5
WHATSAPP_MIN_SECONDS_BETWEEN_SENDS=120
WHATSAPP_REQUIRE_OPT_IN=true
WHATSAPP_REQUIRE_APPROVED_TEMPLATE=true
WHATSAPP_STOP_KEYWORDS=STOP,UNSUBSCRIBE,إيقاف,الغاء,إلغاء
META_PHONE_NUMBER_ID=<your-meta-phone-number-id>
META_WA_ACCESS_TOKEN=<your-meta-wa-access-token>
