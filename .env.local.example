# Dealix local runtime — copy to .env.local (never commit .env.local)
# Cursor: OpenAI only for coding. Dealix app uses keys below.

OPENAI_API_KEY=REPLACE_ME_openai_optional

DEEPSEEK_API_KEY=REPLACE_ME_deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

MINIMAX_API_KEY=REPLACE_ME_minimax
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

AI_PRIMARY_PROVIDER=deepseek
AI_FALLBACK_PROVIDER=minimax

# Admin API for /api/v1/ops-autopilot/* and /api/v1/ai-runtime/*
ADMIN_API_KEYS=REPLACE_ME_local_admin_key

# Optional: match frontend local dev
# NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=REPLACE_ME_local_admin_key
