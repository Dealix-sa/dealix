# Dealix local — copy to .env.local (NEVER commit .env.local)
# Cursor: OpenAI for coding only. All keys below are Dealix runtime.

ENVIRONMENT=development

# ── LLM Runtime ────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_ME_openai
DEEPSEEK_API_KEY=REPLACE_ME_deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Token Plan / Credits key from platform.minimax.io (format sk-api-...)
# Do NOT use old sk-user- keys — they return 401 on chat/completions
MINIMAX_API_KEY=REPLACE_ME_minimax_sk_api
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
AI_PRIMARY_PROVIDER=minimax
AI_FALLBACK_PROVIDER=openai
DEALIX_LLM_PROFILE=minimax

# ── Admin / ops UI ─────────────────────────────────────────────
ADMIN_API_KEYS=REPLACE_ME_local_admin_key
# NEXT_PUBLIC_DEALIX_ADMIN_API_KEY=REPLACE_ME_local_admin_key

# ── PostHog ────────────────────────────────────────────────────
POSTHOG_API_KEY=REPLACE_ME_posthog
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ENABLED=true

# ── Calendly ───────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/sami-assiri11/dealix-demo
CALENDLY_PAT=REPLACE_ME_calendly_pat
CALENDLY_WEBHOOK_SECRET=REPLACE_ME_webhook_signing_key
CALENDLY_OAUTH_CLIENT_ID=REPLACE_ME_oauth_client_id
CALENDLY_OAUTH_CLIENT_SECRET=REPLACE_ME_oauth_client_secret

# ── HubSpot ────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=REPLACE_ME_hubspot_private_app

# ── GitHub (optional) ──────────────────────────────────────────
# GITHUB_TOKEN=REPLACE_ME_github_pat
