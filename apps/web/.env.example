# Dealix web frontend environment
# Copy to .env.local for local Next.js development.

# Public website canonical URL used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://dealix.me

# Public API base URL used by browser-safe calls.
NEXT_PUBLIC_API_URL=https://api.dealix.me

# ── Contact & lead capture ───────────────────────────────────
# WhatsApp number in international digits, no "+" (e.g. 9665XXXXXXXX).
# When empty, WhatsApp CTAs fall back to mailto links.
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Public contact email shown on the site (default: hello@dealix.me).
NEXT_PUBLIC_CONTACT_EMAIL=
# Booking/calendar URL for "book a call" CTAs.
NEXT_PUBLIC_BOOKING_URL=
# Server-side API base for /api/leads forwarding (falls back to
# NEXT_PUBLIC_API_URL; leads degrade gracefully when unreachable).
DEALIX_API_BASE=

# Optional: show internal operational tools in demo/admin surfaces.
NEXT_PUBLIC_SHOW_OPERATIONAL_TOOLS=0

# Recommended: keep privileged operations behind a server-side proxy.
NEXT_PUBLIC_USE_DEALIX_OPS_PROXY=1

# ── Analytics: PostHog ───────────────────────────────────────
# Get from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Error tracking: Sentry ───────────────────────────────────
# Get from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
