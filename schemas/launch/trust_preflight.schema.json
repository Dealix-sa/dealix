{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.me/schemas/launch/trust_preflight.schema.json",
  "title": "TrustPreflightResult",
  "description": "Result of running the trust preflight gate on an outreach draft or content asset.",
  "type": "object",
  "required": ["passed", "violations", "checked_at"],
  "properties": {
    "passed": {
      "type": "boolean",
      "description": "True if all trust rules passed"
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "severity", "message_ar", "message_en"],
        "properties": {
          "rule_id": {
            "type": "string",
            "enum": [
              "T001_no_guarantee_language",
              "T002_no_competitor_defamation",
              "T003_no_pii_exposure",
              "T004_no_spam_patterns",
              "T005_whatsapp_consent_required",
              "T006_arabic_tone_check",
              "T007_claim_accuracy",
              "T008_legal_entity_check",
              "T009_pricing_within_approved_range",
              "T010_enterprise_founder_approval_required"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["BLOCK", "WARN"],
            "description": "BLOCK stops sending; WARN requires founder acknowledgment"
          },
          "message_ar": {
            "type": "string",
            "description": "Arabic explanation of the violation"
          },
          "message_en": {
            "type": "string",
            "description": "English explanation of the violation"
          },
          "matched_text": {
            "type": "string",
            "description": "The specific text that triggered this rule"
          }
        },
        "additionalProperties": false
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "requires_founder_approval": {
      "type": "boolean",
      "description": "True if any WARN-level violations need founder acknowledgment before sending"
    }
  },
  "additionalProperties": false
}
