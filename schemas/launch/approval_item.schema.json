{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.local/schemas/launch/approval_item.schema.json",
  "title": "Dealix Approval Item (launch bundle)",
  "type": "object",
  "required": ["approval_id", "action_category", "draft_id", "channel", "drafted_at_iso", "preflight_status", "founder_review_status", "evidence_level", "risk_level", "approval_required"],
  "additionalProperties": false,
  "properties": {
    "approval_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "action_category": { "enum": ["A_read_only", "B_internal_write", "C_external_draft", "D_external_action", "E_money_action"] },
    "draft_id": { "type": "string" },
    "channel": { "enum": ["email", "linkedin_manual", "phone", "whatsapp_after_consent", "internal"] },
    "target_account_id": { "type": "string" },
    "drafted_by": { "type": "string" },
    "drafted_at_iso": { "type": "string", "format": "date-time" },
    "preflight_status": { "enum": ["PASS", "FAIL", "N/A"] },
    "preflight_run_at_iso": { "type": "string", "format": "date-time" },
    "founder_review_status": { "enum": ["pending", "approved", "rejected", "reversed"] },
    "evidence_level": { "enum": ["L0", "L1", "L2", "L3", "L4", "L5"] },
    "risk_level": { "enum": ["low", "medium", "high"] },
    "approval_required": { "type": "boolean" },
    "approved_at_iso": { "type": "string", "format": "date-time" },
    "approved_by": { "type": "string" },
    "rejection_reason": { "type": "string" },
    "override_reason": { "type": "string" },
    "send_log": {
      "type": "object",
      "properties": {
        "sent_at_iso": { "type": "string", "format": "date-time" },
        "channel_response": { "type": "string" }
      }
    }
  }
}
