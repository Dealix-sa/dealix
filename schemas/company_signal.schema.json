{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/company_signal.schema.json",
  "title": "CompanySignal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signal_id",
    "company",
    "kind",
    "source"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "job_posting",
        "website",
        "content",
        "campaign_launch",
        "careers_page"
      ]
    },
    "detail": {
      "type": "string",
      "description": "e.g., active careers page, campaign/service launch"
    },
    "matched_offer": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "detected_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
