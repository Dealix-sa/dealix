{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/suppression.schema.json",
  "title": "SuppressionEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "email",
    "reason"
  ],
  "properties": {
    "email": {
      "type": "string",
      "description": "Lowercased address that must never be contacted again"
    },
    "reason": {
      "type": "string",
      "enum": [
        "unsubscribe",
        "angry",
        "bounce",
        "manual",
        "do_not_contact"
      ]
    },
    "suppressed_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
