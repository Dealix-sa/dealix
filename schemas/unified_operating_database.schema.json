{
  "name": "unified_operating_database",
  "tables": [
    "accounts",
    "contacts",
    "signals",
    "lead_scores",
    "suppression_list",
    "outreach_queue",
    "conversation_log",
    "sample_queue",
    "proposal_queue",
    "payment_capture_queue",
    "delivery_queue",
    "retention_queue",
    "proof_library",
