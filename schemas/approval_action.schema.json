{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/approval_action.schema.json",
  "title": "ApprovalAction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "draft_id",
    "decision"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "draft_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "description": "Founder decision",
      "enum": [
        "approve",
        "reject",
        "rewrite",
        "shorten",
        "make_formal",
        "change_offer",
        "move_to_nurture",
        "do_not_contact"
      ]
    },
    "note": {
      "type": "string"
    },
    "decided_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
