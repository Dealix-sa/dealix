{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/prospect.schema.json",
  "title": "Prospect",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prospect_id",
    "company",
    "sector",
    "source"
  ],
  "properties": {
    "prospect_id": {
      "type": "string",
      "description": "Stable unique id"
    },
    "company": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "recipient_role": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "description": "Declared lawful source. Forbidden: scraping, purchased_list, cold_whatsapp, linkedin_automation."
    },
    "region": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "state": {
      "type": "string",
      "description": "Lifecycle state",
      "enum": [
        "researched",
        "qualified",
        "draft_ready",
        "drafted",
        "approved",
        "sent",
        "replied",
        "meeting_booked",
        "proposal_needed",
        "proposal_sent",
        "won",
        "lost",
        "nurture",
        "do_not_contact"
      ]
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
