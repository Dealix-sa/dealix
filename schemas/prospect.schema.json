{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/prospect.schema.json",
  "title": "Prospect",
  "description": "A qualified-prospect record in the Revenue Execution OS. Sources are founder-provided; no scraping.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "company", "sector", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^pros_[a-f0-9]+$" },
    "company": { "type": "string" },
    "sector": { "type": "string" },
    "region": { "type": "string" },
    "source": { "type": "string" },
    "decision_maker": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["new", "qualified", "drafted", "contacted", "replied", "discovery_booked", "proposal_needed", "proposal_sent", "payment_handoff", "won", "lost", "nurture"]
    },
    "pain_hypothesis": { "type": "string" },
    "offer_angle": { "type": "string", "description": "A catalog product id or product name" },
    "estimated_value_sar": { "type": "integer", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "preferred_channel": { "type": "string", "enum": ["email", "whatsapp", "linkedin", "phone", "proposal"] },
    "last_contact_at": { "type": "string" },
    "next_action": { "type": "string" },
    "next_action_date": { "type": "string" },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "evidence_level": { "type": "integer", "minimum": 0, "maximum": 5 },
    "created_at": { "type": "string" }
  }
}
