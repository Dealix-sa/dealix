{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/job_signal.schema.json",
  "title": "JobSignal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signal_id",
    "company",
    "kind",
    "source"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "job_posting",
        "website",
        "content",
        "campaign_launch",
        "careers_page"
      ]
    },
    "role": {
      "type": "string",
      "description": "e.g., Sales Ops, CRM Manager, Marketing Coordinator, Support"
    },
    "detail": {
      "type": "string"
    },
    "matched_offer": {
      "type": "string",
      "description": "Offer from the ladder this signal maps to"
    },
    "source": {
      "type": "string",
      "description": "Public/founder-supplied. No scraping."
    },
    "detected_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
