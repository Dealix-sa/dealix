{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "delivery_health_score",
  "title": "Delivery Health Score",
  "type": "object",
  "required": [
    "client_id",
    "client_name",
    "system",
    "scores",
    "total_score",
    "status",
    "computed_at"
  ],
  "properties": {
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "client_name": {
      "type": "string",
      "minLength": 1
    },
    "system": {
      "type": "string",
      "enum": [
        "revenue_operating_system",
        "executive_command_os",
        "followup_recovery_os",
        "whatsapp_client_os",
        "proposal_proof_os"
      ]
    },
    "scores": {
      "type": "object",
      "required": [
        "required_inputs",
        "deliverables",
        "acceptance_criteria",
        "client_uat",
        "sign_off",
        "weekly_value_report"
      ],
      "properties": {
        "required_inputs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "deliverables": {
          "type": "integer",
          "minimum": 0,
          "maximum": 25
        },
        "acceptance_criteria": {
          "type": "integer",
          "minimum": 0,
          "maximum": 25
        },
        "client_uat": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "sign_off": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "weekly_value_report": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        }
      },
      "additionalProperties": false
    },
    "total_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": [
        "delivered_clean",
        "delivered_with_minor_follow_up",
        "needs_revision",
        "not_delivered"
      ]
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
