{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dealix.sa/schemas/reply.schema.json",
  "title": "Reply",
  "description": "A classified inbound reply to an outreach draft. Classification drives the routed next action; 'unsubscribe', 'angry', and 'bounce' trigger immediate suppression. No personal data is stored in `notes` (NO_PII).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0", "default": "1.0", "type": "string" },
    "reply_id": { "type": "string" },
    "draft_id": { "type": "string" },
    "prospect_id": { "type": "string" },
    "classification": {
      "type": "string",
      "enum": [
        "positive",
        "interested_but_later",
        "price_question",
        "send_more_info",
        "not_interested",
        "wrong_person",
        "unsubscribe",
        "angry",
        "auto_reply",
        "bounce"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 },
    "recommended_action": { "type": "string", "description": "Routed next action for this classification." },
    "requires_founder": { "type": "boolean", "default": true },
    "language": { "type": "string", "enum": ["ar", "en"], "default": "ar" },
    "received_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string", "description": "MUST NOT contain personal data (NO_PII).", "maxLength": 2000 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["reply_id", "classification"]
}
