{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.sa/schemas/reply.schema.json",
  "title": "Reply",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reply_id",
    "draft_id",
    "reply_class"
  ],
  "properties": {
    "reply_id": {
      "type": "string"
    },
    "draft_id": {
      "type": "string"
    },
    "prospect_id": {
      "type": "string"
    },
    "text": {
      "type": "string",
      "description": "Stored only as the founder records it; no PII in derived logs"
    },
    "reply_class": {
      "type": "string",
      "enum": [
        "positive",
        "interested_later",
        "price_question",
        "send_more_info",
        "wrong_person",
        "not_interested",
        "unsubscribe",
        "angry",
        "auto_reply",
        "bounce"
      ]
    },
    "next_action": {
      "type": "string"
    },
    "suppress": {
      "type": "boolean",
      "description": "true for unsubscribe/angry/bounce"
    },
    "received_at": {
      "type": "string",
      "description": "ISO-8601"
    }
  }
}
