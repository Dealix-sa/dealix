{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 524288
  },
  "output": {
    "filePath": "dealix-ai-context.md",
    "style": "markdown",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "topFilesLength": 20,
    "includeEmptyDirectories": false
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      "coverage/**",
      "*.lock",
      "*.log",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.svg",
      "*.ico",
      "*.woff",
      "*.woff2",
      "*.ttf",
      "*.pdf",
      "*.zip",
      "*.tar.gz",
      ".git/**",
      "__pycache__/**",
      "*.pyc",
      "*.pyo",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      "htmlcov/**",
      "reports/**",
      "tmp/**",
      "data/**",
      ".env*",
      "*.env",
      "secrets/**",
      "dealix-ai-context.md",
      "frontend/node_modules/**",
      "apps/web/node_modules/**",
      "apps/web/.next/**",
      "alembic/versions/**",
      "supabase/**",
      "landing/**",
      "demos/**",
      "design-systems/**",
      "evals/**",
      "*.min.js",
      "*.min.css",
      "package-lock.json",
      "*.lock"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
