# Dealix Exa / Data Intelligence environment example
# Copy these values into Railway Variables, GitHub Secrets, or local .env.
# Do not commit a real EXA_API_KEY.

EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_DEFAULT_SEARCH_TYPE=auto
EXA_DEEP_SEARCH_TYPE=deep
EXA_NUM_RESULTS=10
EXA_ALLOW_LIVE_SEARCH=true
EXA_STORE_RAW_TEXT=false
EXA_REQUIRE_SOURCE_URL=true
EXA_REQUIRE_HUMAN_REVIEW=true
DATA_INTELLIGENCE_CITY=Riyadh
DATA_INTELLIGENCE_MODE=review_first
