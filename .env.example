# Dealix Environment Configuration | إعدادات بيئة Dealix
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# ============================================================
# APP / ENVIRONMENT
# ============================================================
APP_ENV=development            # development | staging | production | test
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Riyadh
APP_DEFAULT_LOCALE=ar
APP_DEFAULT_CURRENCY=SAR
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Backend app secret — generate a real 64-byte hex value in prod.
# PLACEHOLDER: replace with secrets.token_hex(32) in production
APP_SECRET_KEY=<PLACEHOLDER_GENERATE_WITH_secrets_token_hex_32>

# Legacy env keys (referenced by scripts/check_env_contract.py and
# scripts/dealix_customer_credentials_check.py). APP_ENV / APP_LOG_LEVEL
# above are the canonical pydantic-settings keys; these mirror them.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Git SHA surfaced on /health (auto-set by Dockerfile/Railway).
GIT_SHA=unknown

# Public base URLs (used by frontend, email links, webhooks).
BASE_URL=http://localhost:8000
DEALIX_API_BASE=http://localhost:8000

# ============================================================
# OUTBOUND SAFETY — all disabled by default. Never enable in .env.example.
# ============================================================
EXTERNAL_SEND_ENABLED=false
OUTBOUND_MODE=draft_only
EMAIL_SEND_ENABLED=false
WHATSAPP_SEND_ENABLED=false
WHATSAPP_ALLOW_LIVE_SEND=false
SMS_SEND_ENABLED=false

# ============================================================
# AUTH / JWT  (required in production — startup fails otherwise)
# ============================================================
# 32+ char hex. Generate: python -c "import secrets; print(secrets.token_hex(32))"
# PLACEHOLDER: replace with secrets.token_hex(32) in production
JWT_SECRET_KEY=<PLACEHOLDER_GENERATE_WITH_secrets_token_hex_32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_INVITE_TOKEN_EXPIRE_HOURS=72

# Comma-separated client API keys for /api/v1/* (non-admin).
API_KEYS=
# Comma-separated admin API keys for /api/v1/admin/*.
ADMIN_API_KEYS=

# ============================================================
# DATABASES
# ============================================================
# Postgres in prod. Railway/Heroku `postgres://…` is auto-normalized to asyncpg.
# PLACEHOLDER: replace with real credentials
DATABASE_URL=postgresql+asyncpg://<USER>:<PASSWORD>@localhost:5432/<DB>
REDIS_URL=redis://localhost:6379/0
# PLACEHOLDER: replace with real MongoDB URI
MONGODB_URI=mongodb://localhost:27017/<DB>

# Proof / Value / Operational ledgers backend selection.
PROOF_LEDGER_BACKEND=file          # file | postgres
VALUE_LEDGER_BACKEND=jsonl         # jsonl | postgres | dual
DEALIX_OPERATIONAL_STREAM_BACKEND=off   # off | postgres | dual
OTEL_CONTRACT_TRACE_EXPORT=false

# Communication OS persistence.
# staging/production require postgres; file is local/test only.
DEALIX_COMMS_STORAGE_BACKEND=file  # file | postgres
DEALIX_COMMS_NAMESPACE=dealix
DEALIX_COMMS_FILE_ROOT=data/comms

# ============================================================
# LLM PROVIDERS  (at least ANTHROPIC_API_KEY required for 11 Hermes agents)
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=60

# OpenRouter gears (cost-routed multi-tier strategy).
GEAR1_MODEL=deepseek/deepseek-chat
GEAR2_MODEL=minimax/minimax-m2.5
GEAR3_MODEL=minimax/minimax-m2.7

# Optional fallbacks.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GROQ_API_KEY=
GROQ_BASE_URL=https://groq.com/openai/v1

# ============================================================
# SAUDI INTEGRATIONS
# ============================================================
# Moyasar payments — https://moyasar.com/dashboard
# MOYASAR_SECRET_KEY is the HTTP Basic username (secret key).
# MOYASAR_WEBHOOK_SECRET validates signed webhooks (constant-time compare).
# PLACEHOLDER: replace with test keys from Moyasar dashboard
MOYASAR_API_KEY=<PLACEHOLDER>
MOYASAR_SECRET_KEY=<PLACEHOLDER>
MOYASAR_WEBHOOK_SECRET=
MOYASAR_LIVE_MODE=false

# ZATCA e-invoice Phase 2 — https://zatca.gov.sa
ZATCA_CSID=
ZATCA_SECRET=
ZATCA_SANDBOX=true
ZATCA_SELLER_NAME=
ZATCA_SELLER_VAT=
ZATCA_SELLER_CRN=
ZATCA_SELLER_CITY=Riyadh
ZATCA_SELLER_STREET=
ZATCA_SELLER_POSTAL=

# WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# WHATSAPP_ALLOW_LIVE_SEND is set in the OUTBOUND SAFETY section above.

# ============================================================
# EMAIL  (provider set via EMAIL_PROVIDER)
# ============================================================
EMAIL_PROVIDER=resend           # resend | sendgrid | smtp
EMAIL_FROM=noreply@dealix.me
EMAIL_FROM_NAME=Dealix
DEALIX_FOUNDER_EMAIL=founder@dealix.me
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=founder@dealix.me
SMTP_PASSWORD=
SMTP_TLS=true

# ============================================================
# LEAD RESEARCH / CRM / CALENDAR
# ============================================================
GOOGLE_MAPS_API_KEY=
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
GOOGLE_CALENDAR_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=primary
CALENDLY_API_TOKEN=
CALENDLY_USER_URI=

# ============================================================
# AUTOMATION
# ============================================================
N8N_WEBHOOK_URL=
N8N_ENCRYPTION_KEY=

# ============================================================
# OBSERVABILITY
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# OTHER
# ============================================================
CLICKBANK_API_KEY=
HIX_AI_API_KEY=
