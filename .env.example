# Dealix Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================
# REQUIRED: Lead Research (Google Places API)
# ============================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Steps:
#   1. Create API key in Google Cloud Console
#   2. Enable Google Places API
#   3. Copy key below
GOOGLE_MAPS_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# OPTIONAL PHASE 2: WhatsApp Business API
# ============================================================
# Get from: https://developers.facebook.com/docs/whatsapp/cloud-api
# For automated WhatsApp sending (Phase 3)
WHATSAPP_API_KEY=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=

# ============================================================
# OPTIONAL PHASE 2: Moyasar Payment Gateway
# ============================================================
# Get from: https://moyasar.com/dashboard
# For automated payment link generation (Phase 3)
MOYASAR_API_KEY=pk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOYASAR_API_SECRET=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOYASAR_LIVE_MODE=false

# ============================================================
# OPTIONAL PHASE 4: Email (SMTP)
# ============================================================
# For automated email sending (Phase 4)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sami.assiri11@gmail.com
SMTP_PASSWORD=

# ============================================================
# SYSTEM CONFIGURATION
# ============================================================
# Default timezone for all timestamps and scheduling
TIMEZONE=Asia/Riyadh

# Enable debug logging (true/false)
DEBUG_MODE=false

# System environment (development/staging/production)
ENVIRONMENT=development

# Log verbosity (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Backend app secret — generate a strong random value in real environments.
# NEVER commit a real secret; this placeholder is for local/dev only.
APP_SECRET_KEY=change-me-in-production

# Public base URL of the backend API.
APP_URL=http://localhost:8000

# Database connection string (Postgres in prod; sqlite acceptable locally).
DATABASE_URL=sqlite+aiosqlite:///./dealix.db

# Comma-separated admin API keys for privileged ops endpoints.
# Leave blank locally; set strong values in staging/production.
ADMIN_API_KEYS=

# Comma-separated allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000
