{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.ai/schemas/persuasion-dossier.schema.json",
  "title": "PersuasionDossier",
  "description": "A persuasion dossier prepared for a prospect company before outreach",
  "type": "object",
  "required": [
    "company",
    "country",
    "language",
    "sector",
    "buyer",
    "likely_pain",
    "best_offer",
    "best_channel",
    "persuasion_score",
    "message_pack"
  ],
  "properties": {
    "company": {
      "type": "string",
      "minLength": 1,
      "description": "Target company name"
    },
    "country": {
      "type": "string",
      "description": "Country code"
    },
    "language": {
      "type": "string",
      "enum": ["arabic", "english", "bilingual"],
      "description": "Language for outreach"
    },
    "sector": {
      "type": "string",
      "description": "Industry sector slug"
    },
    "buyer": {
      "type": "string",
      "description": "Target buyer title or name"
    },
    "likely_pain": {
      "type": "string",
      "minLength": 10,
      "description": "Specific operational pain identified for this company"
    },
    "best_offer": {
      "type": "string",
      "description": "Recommended offer ID"
    },
    "best_channel": {
      "type": "string",
      "description": "Primary recommended channel"
    },
    "persuasion_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall persuasion quality score (must be >= 82 to execute)"
    },
    "score_breakdown": {
      "type": "object",
      "description": "Score breakdown per rubric dimension",
      "properties": {
        "company_understanding": {"type": "number", "minimum": 0, "maximum": 15},
        "pain_clarity": {"type": "number", "minimum": 0, "maximum": 15},
        "offer_fit": {"type": "number", "minimum": 0, "maximum": 15},
        "buyer_fit": {"type": "number", "minimum": 0, "maximum": 10},
        "channel_fit": {"type": "number", "minimum": 0, "maximum": 10},
        "first_line_quality": {"type": "number", "minimum": 0, "maximum": 10},
        "risk_reversal": {"type": "number", "minimum": 0, "maximum": 10},
        "cta_clarity": {"type": "number", "minimum": 0, "maximum": 5},
        "no_exaggeration": {"type": "number", "minimum": 0, "maximum": 5},
        "language_fit": {"type": "number", "minimum": 0, "maximum": 5}
      }
    },
    "message_pack": {
      "type": "object",
      "required": ["subject", "body"],
      "description": "Prepared outreach message",
      "properties": {
        "subject": {
          "type": "string",
          "description": "Email subject line or LinkedIn message preview"
        },
        "body": {
          "type": "string",
          "description": "Full message body"
        },
        "cta": {
          "type": "string",
          "description": "Call to action"
        },
        "language": {
          "type": "string",
          "enum": ["arabic", "english", "bilingual"]
        }
      }
    },
    "company_signals": {
      "type": "object",
      "description": "Public signals observed about the company"
    },
    "source_ref": {
      "type": "string",
      "description": "Source of company information"
    },
    "fit_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Company fit score from company_scorer"
    },
    "tier": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "ready_to_execute": {
      "type": "boolean",
      "description": "True only if persuasion_score >= 82 and founder_approved = true"
    },
    "founder_approved": {
      "type": "boolean",
      "description": "Has the founder approved this dossier for execution?"
    },
    "governance_decision": {
      "type": "object",
      "required": ["module", "persuasion_score", "ready_to_execute"],
      "properties": {
        "module": {"type": "string"},
        "persuasion_score": {"type": "number"},
        "ready_to_execute": {"type": "boolean"},
        "founder_approved": {"type": "boolean"},
        "blocked_reason": {"type": "string"}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
