{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealix.ai/schemas/reply.schema.json",
  "title": "Reply",
  "description": "A reply received from a prospect, classified by the OS",
  "type": "object",
  "required": ["reply_id", "company", "channel", "classification", "received_at"],
  "properties": {
    "reply_id": {"type": "string"},
    "company": {"type": "string"},
    "channel": {"type": "string"},
    "classification": {
      "type": "string",
      "enum": [
        "positive_interested",
        "positive_meeting_request",
        "positive_information_request",
        "neutral_send_more_info",
        "neutral_not_now",
        "neutral_wrong_person",
        "negative_not_interested",
        "negative_unsubscribe",
        "negative_complaint",
        "auto_reply",
        "bounce",
        "unknown"
      ]
    },
    "sentiment": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "unknown"]
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the reply content — NO PII, no raw message body"
    },
    "next_action": {
      "type": "string",
      "description": "Recommended next action based on classification"
    },
    "opportunity_stage_update": {
      "type": "string",
      "description": "New pipeline stage if this reply triggers a stage change"
    },
    "received_at": {"type": "string", "format": "date-time"},
    "classified_at": {"type": "string", "format": "date-time"},
    "classified_by": {
      "type": "string",
      "enum": ["agent", "founder"]
    },
    "governance_decision": {
      "type": "object",
      "required": ["module"],
      "properties": {
        "module": {"type": "string"},
        "classification": {"type": "string"},
        "next_action": {"type": "string"}
      }
    }
  }
}
